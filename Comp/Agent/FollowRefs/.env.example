AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini
OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_API_KEY=<your-api-key>

# メール送信設定 (send_email ツール用)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-account@example.com
SMTP_PASSWORD=your-password
SMTP_FROM=your-account@example.com
# STARTTLS=true の場合は SMTP + STARTTLS、false の場合は SMTP_SSL (port 465)
SMTP_USE_STARTTLS=true
# エージェント設定ファイルのパス (デフォルト: agent_config.yaml)
# AGENT_CONFIG=agent_config.yaml

# Active Directory / LDAP 設定 (search_active_directory ツール用)
LDAP_SERVER=ldap://your-domain-controller.example.com
LDAP_PORT=389
LDAP_USE_SSL=false
LDAP_BIND_DN=DOMAIN\service_account
LDAP_BIND_PASSWORD=your-password
LDAP_SEARCH_BASE=dc=example,dc=com
